{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_policy.py\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & (Join-Path $root '.codex/hooks/run-pre-tool-use-policy.ps1')\"",
            "timeout": 30,
            "statusMessage": "Checking ponkan-python command policy"
          }
        ]
      }
    ]
  }
}
